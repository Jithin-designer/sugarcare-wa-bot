# Copy to .env and fill in real values. .env is gitignored — never commit it.

# ── Meta WhatsApp Cloud API ──────────────────────────────────────────────────
# Permanent access token (System User token recommended over a temp token).
WHATSAPP_TOKEN=your_permanent_access_token_here

# The phone number id and WhatsApp Business Account id from Meta > WhatsApp > API Setup.
PHONE_NUMBER_ID=1232912896566193
WABA_ID=3507409086077679

# App secret from Meta > App Settings > Basic. Used to validate X-Hub-Signature-256
# on every inbound POST. If unset in MOCK_MODE, a dev default is used (with a warning).
APP_SECRET=your_app_secret_here

# The verify token you invent here AND paste into Meta's webhook config (GET handshake).
VERIFY_TOKEN=choose_a_random_string_here

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# MOCK_MODE=true  → outbound messages are console-logged + appended to data/mock_outbox.jsonl
# MOCK_MODE=false → outbound messages POST to graph.facebook.com (real WhatsApp)
MOCK_MODE=true

# SQLite database file (optional; defaults to data/bot.db). Use :memory: for throwaway runs.
DB_PATH=data/bot.db

# ── Admin panel (separate process, port 3010) ────────────────────────────────
# Secret used to sign session cookies. Generate a long random string.
# (If unset in MOCK_MODE, a dev default is used with a warning.)
ADMIN_SESSION_SECRET=choose_a_long_random_string_here

# Port for the admin panel (optional; defaults to 3010).
ADMIN_PORT=3010

# The default admin users are seeded with password 1234. Only bcrypt hashes are
# stored; no per-user seed-password environment variables are required.
